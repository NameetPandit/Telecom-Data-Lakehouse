obalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"d8494058-5edb-4986-941f-3522ebd22b02"},{"version":"CommandV1","origId":1423076379966139,"guid":"bd9b60b3-14d8-4f88-afea-3f9d3c55fb44","subtype":"command","commandType":"auto","position":19.0,"command":"df_tickets_quarantine = df_q_dq_tkt_02.unionByName(df_q_dq_tkt_03)\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"e5fc51ce-c5df-4b3b-b597-e8b8cd7b1e7c"},{"version":"CommandV1","origId":1423076379966140,"guid":"edbee882-fc60-4ef4-9084-22b5e0b445c5","subtype":"command","commandType":"auto","position":20.0,"command":"df_tickets_quarantine.write.format(\"delta\") \\\n    .mode(\"append\") \\\n    .option(\"mergeSchema\", \"true\")\\\n    .saveAsTable(\"telecom_lakehouse.quarantine.tickets_rejected\")","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"89f1205b-30dc-46d9-a71e-b8171c912745"},{"version":"CommandV1","origId":1423076379966141,"guid":"38c98a30-1126-4845-b131-84b9b9624c5c","subtype":"command","commandType":"auto","position":21.0,"command":"df_valid_tickets = df_ticket_cell_fixed.filter(\n    ~(\n        ((col(\"status\") == \"OPEN\") & col(\"resolution_time_min\").cast(\"double\").isNotNull())\n    )\n)","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"a1799890-78de-43fd-8e0a-3438c95cc0a0"},{"version":"CommandV1","origId":1423076379966142,"guid":"12fe1db6-9788-44af-8c5d-014914d82df1","subtype":"command","commandType":"auto","position":22.0,"command":"df_valid_tickets.write.format(\"delta\").mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.silver.fact_tickets\")\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"5cec49a8-4e1f-4137-a9e7-c9616a224322"},{"version":"CommandV1","origId":1423076379966144,"guid":"a3194a8a-5472-48b1-85b9-43ee5b648ad2","subtype":"command","commandType":"auto","position":23.0,"command":"%md\n## qurantine","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"dba34d5d-5329-4a4f-9ad3-61858740cbf7"},{"version":"CommandV1","origId":1423076379966145,"guid":"42106d2e-50e7-47ac-bad3-2fc8a4f78956","subtype":"command","commandType":"auto","position":24.0,"command":"# Cell 1: Fix QoS Quarantine Data\nfrom pyspark.sql.functions import col, abs, expr, when, upper, regexp_replace, coalesce\n\n# 1. Get List of Rejected IDs from Quarantine\nrejected_qos_ids = spark.table(\"telecom_lakehouse.quarantine.qos_rejected\").select(\"qos_event_id\")\n\n# 2. Fetch Full Original Data from Bronze (Join on ID)\ndf_remediated_qos = spark.table(\"telecom_lakehouse.bronze.raw_qos_logs\") \\\n    .join(rejected_qos_ids, \"qos_event_id\", \"inner\")\n\n# 3. Apply Logic (Exact Match to Stream) + THE FIX\ndf_fixed_qos = (df_remediated_qos\n    # --- SAME TRANSFORMATIONS AS YOUR STREAM ---\n    .withColumn(\"event_ts\", \n        coalesce(\n            expr(\"try_to_timestamp(event_ts, 'M/d/yyyy HH:mm')\"), \n            expr(\"try_to_timestamp(event_ts, 'yyyy-MM-dd HH:mm:ss')\"),\n            expr(\"try_cast(event_ts as timestamp)\")\n        )\n    )\n    .withColumnRenamed(\"region\", \"region_id\") # Matches your specific logic\n    .withColumn(\"latency_ms\", col(\"latency_ms\").cast(\"double\"))\n    .withColumn(\"jitter_ms\", col(\"jitter_ms\").cast(\"double\"))\n    .withColumn(\"signal_rsrp_dbm\", col(\"signal_rsrp_dbm\").cast(\"double\"))\n    .withColumn(\"cell_id\", upper(regexp_replace(col(\"cell_id\"), \"[^a-zA-Z0-9]\", \"\")))\n    .withColumn(\"technology\", \n         when(upper(col(\"technology\")).rlike(\"LTE|4G\"), \"4G\")\n        .when(upper(col(\"technology\")).rlike(\"NR|5G\"), \"5G\")\n        .otherwise(\"UNKNOWN\")\n    )\n    # --- THE FIX (Remediation) ---\n    # Convert negative throughput/loss to positive using abs()\n    .withColumn(\"throughput_mbps\", abs(col(\"throughput_mbps\").cast(\"double\"))) \n    .withColumn(\"packet_loss_pct\", abs(col(\"packet_loss_pct\").cast(\"double\")))\n)\n\n# 4. Write Fixed Data to Silver\n# We use 'append' to add these recovered rows to the main table\ndf_fixed_qos.write.format(\"delta\") \\\n    .mode(\"append\") \\\n    .option(\"mergeSchema\", \"true\") \\\n    .saveAsTable(\"telecom_lakehouse.silver.fact_qos\")\n\nprint(f\" QoS Remediation Complete: Fixed and loaded {df_fixed_qos.count()} records.\")","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"f635b9fb-a753-4d23-b925-7334c1612571"},{"version":"CommandV1","origId":1423076379966146,"guid":"e9a6680d-18c8-4615-a0b6-3a39529d8904","subtype":"command","commandType":"auto","position":25.0,"command":"%sql\ncreate or replace table temp_tickets_tb \nas\nselect * from telecom_lakehouse.bronze.tickets_raw where ticket_id in (select ticket_id from telecom_lakehouse.quarantine.tickets_rejected);","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"7193ece0-acc5-4335-9119-f97d677f3c02"},{"version":"CommandV1","origId":1423076379966147,"guid":"d980ccc2-85b4-4cdf-aa72-58262f11990b","subtype":"command","commandType":"auto","position":26.0,"command":"%sql\nupdate temp_tickets_tb set priority = 'P1' where priority = 'High';","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"f3d43669-290f-414b-81d4-f4a2305ded2e"},{"version":"CommandV1","origId":1423076379966148,"guid":"94a7cdcb-5840-4e4f-8845-99332d5ec2a1","subtype":"command","commandType":"auto","position":27.0,"command":"%sql\nupdate temp_tickets_tb set priority = 'P2' where priority = 'p2';","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"df065a51-78f8-4426-9d24-89eede997258"},{"version":"CommandV1","origId":1423076379966149,"guid":"76b55b09-5dad-4d2f-9c77-ab841f2768e6","subtype":"command","commandType":"auto","position":28.0,"command":"%sql\nupdate temp_tickets_tb set resolution_time_min = null where status = \"OPEN\";","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"f904b274-c01b-4667-9abf-61054c238161"},{"version":"CommandV1","origId":1423076379966150,"guid":"9a995f53-1741-4b2d-bee4-3c85d5771090","subtype":"command","commandType":"auto","position":29.0,"command":"%sql\nmerge into telecom_lakehouse.silver.fact_tickets t\nusing temp_tickets_tb s\non t.ticket_id = s.ticket_id\nwhen matched then update set *\nwhen not matched then insert *","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"6100f6f3-2e1f-41e4-af46-09aa1ca7680a"},{"version":"CommandV1","origId":1423076379966151,"guid":"63ceed5b-0e05-4fee-b7c6-d2e9bb5f19c4","subtype":"command","commandType":"auto","position":30.0,"command":"%sql\nselect count(*) from telecom_lakehouse.silver.fact_tickets where status = \"OPEN\" and resolution_time_min < 0; ","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"df4d9128-7d7d-4ca6-ac60-65eaca0db2d0"},{"version":"CommandV1","origId":1423076379966152,"guid":"066732db-850b-43d6-81c2-21e11805ce6d","subtype":"command","commandType":"auto","position":31.0,"command":"%sql\nUPDATE telecom_lakehouse.silver.fact_tickets\nSET resolution_time_min = (\n    SELECT ROUND(AVG(resolution_time_min), 2)\n    FROM telecom_lakehouse.silver.fact_tickets\n    WHERE status = 'CLOSED'\n)\nWHERE status = 'CLOSED' and resolution_time_min is null;","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"05225ceb-f902-49a0-8ec4-3b0b229b3f95"},{"version":"CommandV1","origId":1423076379966153,"guid":"5e9f015c-3bbb-4b3e-bad8-fd74ab2c5a49","subtype":"command","commandType":"auto","position":32.0,"command":"%md\n## gold","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"18b6c894-8df6-4367-91b7-d6f75921d0a3"},{"version":"CommandV1","origId":1423076379966154,"guid":"363a447d-ef5e-42e9-bc7c-4a569894ea3e","subtype":"command","commandType":"auto","position":33.0,"command":"# Cell 2: Dimensions with Fast IDs & Explicit Schema\nfrom delta.tables import DeltaTable\nfrom pyspark.sql.types import StructType, StructField, StringType, LongType, TimestampType, BooleanType\nfrom pyspark.sql.functions import (\n    col, lit, max as spark_max, monotonically_increasing_id, current_timestamp, \n    to_date, expr, when, coalesce\n)\n\n# Helper to get next sequence start\ndef get_next_sk_start(table_name, sk_col):\n    if spark.catalog.tableExists(table_name):\n        max_val = spark.table(table_name).agg(spark_max(col(sk_col))).collect()[0][0]\n        return (max_val + 1) if max_val is not None else 1\n    return 1\n\n# ==========================================\n# 1. DIM CELL (SCD Type 2)\n# ==========================================\ndf_cell_src = spark.table(\"telecom_lakehouse.reference.dim_cells\") \\\n    .select(\"cell_id\", \"vendor\", \"site_type\")\n\ntable_name_cell = \"telecom_lakehouse.gold.dim_cell\"\n\nif not spark.catalog.tableExists(table_name_cell):\n    print(\"Initializing dim_cell...\")\n    \n    # 1. Create Main Data\n    df_cell_init = df_cell_src \\\n        .withColumn(\"cell_sk\", monotonically_increasing_id()) \\\n        .withColumn(\"valid_from\", current_timestamp()) \\\n        .withColumn(\"valid_to\", expr(\"CAST(NULL AS TIMESTAMP)\")) \\\n        .withColumn(\"is_current\", lit(True))\n    \n    # 2. Define Schema for Unknown Row (Fixes Type Error)\n    cell_schema = StructType([\n        StructField(\"cell_id\", StringType(), True),\n        StructField(\"vendor\", StringType(), True),\n        StructField(\"site_type\", StringType(), True),\n        StructField(\"cell_sk\", LongType(), True),\n        StructField(\"valid_from\", TimestampType(), True),\n        StructField(\"valid_to\", TimestampType(), True),\n        StructField(\"is_current\", BooleanType(), True)\n    ])\n    \n    # 3. Create Unknown Row safely\n    unknown_data = [(\"UNKNOWN\", \"UNKNOWN\", \"N/A\", -1, None, None, True)]\n    \n    df_unknown = spark.createDataFrame(unknown_data, schema=cell_schema) \\\n        .withColumn(\"valid_from\", lit(\"1900-01-01 00:00:00\").cast(\"timestamp\"))\n\n    df_cell_init.unionByName(df_unknown).write.format(\"delta\").saveAsTable(table_name_cell)\n\nelse:\n    print(\"Merging updates to dim_cell...\")\n    delta_cell = DeltaTable.forName(spark, table_name_cell)\n    df_target = delta_cell.toDF()\n    \n    df_updates = df_cell_src.alias(\"s\").join(\n        df_target.alias(\"t\"),\n        (col(\"s.cell_id\") == col(\"t.cell_id\")) & (col(\"t.is_current\") == True),\n        \"left\"\n    ).select(col(\"s.cell_id\"), col(\"s.vendor\"), col(\"s.site_type\"), col(\"t.cell_id\").alias(\"t_cell_id\"), col(\"t.vendor\").alias(\"t_vendor\"), col(\"t.site_type\").alias(\"t_site_type\"))\n\n    df_changed = df_updates.filter(col(\"t_cell_id\").isNull() | (col(\"s.vendor\") != col(\"t_vendor\")) | (col(\"s.site_type\") != col(\"t_site_type\")))\n\n    # ID Logic\n    start_sk = get_next_sk_start(table_name_cell, \"cell_sk\")\n    \n    df_new = df_changed.select(\n        col(\"cell_id\"), col(\"vendor\"), col(\"site_type\"),\n        (monotonically_increasing_id() + lit(start_sk)).alias(\"cell_sk\"), \n        lit(None).alias(\"mergeKey\")\n    )\n    df_old = df_changed.filter(col(\"t_cell_id\").isNotNull()).select(col(\"cell_id\"), col(\"vendor\"), col(\"site_type\"), lit(None).cast(\"long\").alias(\"cell_sk\"), col(\"cell_id\").alias(\"mergeKey\"))\n    \n    df_merge = df_new.unionByName(df_old, allowMissingColumns=True)\n\n    delta_cell.alias(\"t\").merge(df_merge.alias(\"s\"), (col(\"t.cell_id\") == col(\"s.mergeKey\")) & (col(\"t.is_current\") == True)) \\\n        .whenMatchedUpdate(set={\"is_current\": lit(False), \"valid_to\": current_timestamp()}) \\\n        .whenNotMatchedInsert(values={\"cell_sk\": col(\"s.cell_sk\"), \"cell_id\": col(\"s.cell_id\"), \"vendor\": col(\"s.vendor\"), \"site_type\": col(\"s.site_type\"), \"valid_from\": current_timestamp(), \"valid_to\": lit(None), \"is_current\": lit(True)}) \\\n        .execute()\n\n\n# ==========================================\n# 2. DIM CUSTOMER (SCD Type 2)\n# ==========================================\ndf_cust_src = spark.table(\"telecom_lakehouse.reference.dim_customers\") \\\n    .withColumnRenamed(\"customers\", \"customer_id\") \\\n    .withColumnRenamed(\"segments\", \"segment\") \\\n    .select(\"customer_id\", \"segment\")\n\ntable_name_cust = \"telecom_lakehouse.gold.dim_customer\"\n\nif not spark.catalog.tableExists(table_name_cust):\n    print(\"Initializing dim_customer...\")\n    \n    df_cust_init = df_cust_src \\\n        .withColumn(\"customer_sk\", monotonically_increasing_id()) \\\n        .withColumn(\"valid_from\", current_timestamp()) \\\n        .withColumn(\"valid_to\", expr(\"CAST(NULL AS TIMESTAMP)\")) \\\n        .withColumn(\"is_current\", lit(True))\n\n    # Explicit Schema\n    cust_schema = StructType([\n        StructField(\"customer_id\", StringType(), True),\n        StructField(\"segment\", StringType(), True),\n        StructField(\"customer_sk\", LongType(), True),\n        StructField(\"valid_from\", TimestampType(), True),\n        StructField(\"valid_to\", TimestampType(), True),\n        StructField(\"is_current\", BooleanType(), True)\n    ])\n\n    unknown_data_c = [(\"UNKNOWN\", \"N/A\", -1, None, None, True)]\n    \n    df_unknown_c = spark.createDataFrame(unknown_data_c, schema=cust_schema) \\\n        .withColumn(\"valid_from\", lit(\"1900-01-01 00:00:00\").cast(\"timestamp\"))\n\n    df_cust_init.unionByName(df_unknown_c).write.format(\"delta\").saveAsTable(table_name_cust)\n\nelse:\n    print(\"Merging updates to dim_customer...\")\n    delta_cust = DeltaTable.forName(spark, table_name_cust)\n    df_target_c = delta_cust.toDF()\n\n    df_updates_c = df_cust_src.alias(\"s\").join(df_target_c.alias(\"t\"), (col(\"s.customer_id\") == col(\"t.customer_id\")) & (col(\"t.is_current\") == True), \"left\") \\\n        .select(col(\"s.customer_id\"), col(\"s.segment\"), col(\"t.customer_id\").alias(\"t_customer_id\"), col(\"t.segment\").alias(\"t_segment\"))\n\n    df_changed_c = df_updates_c.filter(col(\"t_customer_id\").isNull() | (col(\"s.segment\") != col(\"t_segment\")))\n\n    start_sk_c = get_next_sk_start(table_name_cust, \"customer_sk\")\n\n    df_new_c = df_changed_c.select(\n        col(\"customer_id\"), col(\"segment\"),\n        (monotonically_increasing_id() + lit(start_sk_c)).alias(\"customer_sk\"),\n        lit(None).alias(\"mergeKey\")\n    )\n    df_old_c = df_changed_c.filter(col(\"t_customer_id\").isNotNull()).select(col(\"customer_id\"), col(\"segment\"), lit(None).cast(\"long\").alias(\"customer_sk\"), col(\"customer_id\").alias(\"mergeKey\"))\n    \n    df_merge_c = df_new_c.unionByName(df_old_c, allowMissingColumns=True)\n\n    delta_cust.alias(\"t\").merge(df_merge_c.alias(\"s\"), (col(\"t.customer_id\") == col(\"s.mergeKey\")) & (col(\"t.is_current\") == True)) \\\n        .whenMatchedUpdate(set={\"is_current\": lit(False), \"valid_to\": current_timestamp()}) \\\n        .whenNotMatchedInsert(values={\"customer_sk\": col(\"s.customer_sk\"), \"customer_id\": col(\"s.customer_id\"), \"segment\": col(\"s.segment\"), \"valid_from\": current_timestamp(), \"valid_to\": lit(None), \"is_current\": lit(True)}) \\\n        .execute()\n\n# ==========================================\n# 3. Static Dimensions\n# ==========================================\ndf_issue = spark.table(\"telecom_lakehouse.silver.fact_tickets\").select(\"issue_type\").distinct().filter(col(\"issue_type\").isNotNull()) \\\n    .withColumn(\"issue_sk\", monotonically_increasing_id()) \\\n    .withColumn(\"severity_default\", lit(\"Standard\"))\n\n# Explicit Schema for Issue Type\nissue_schema = StructType([\n    StructField(\"issue_sk\", LongType(), True),\n    StructField(\"issue_type\", StringType(), True),\n    StructField(\"severity_default\", StringType(), True)\n])\nunknown_issue = spark.createDataFrame([(-1, \"UNKNOWN\", \"Standard\")], schema=issue_schema)\n\ndf_issue.unionByName(unknown_issue).write.format(\"delta\").mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.gold.dim_issue_type\")\n\n# Dim Date\nfrom pyspark.sql.functions import explode, sequence, year, month, dayofmonth, date_format, weekofyear\nspark.sql(\"\"\"CREATE OR REPLACE TABLE telecom_lakehouse.gold.dim_date AS SELECT date_key, year(date_key) as year, month(date_key) as month, day(date_key) as day, date_format(date_key, 'E') as day_name, weekofyear(date_key) as week_num FROM (SELECT explode(sequence(to_date('2024-01-01'), to_date('2025-12-31'), interval 1 day)) as date_key)\"\"\")\n\nprint(\"All Dimensions Created Successfully (SCD Fixed & Type Safe).\")","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"b5913d5d-7c94-49f5-8534-0b78d60049dd"},{"version":"CommandV1","origId":1423076379966155,"guid":"958cc180-a752-42d1-be44-21a9089afcc0","subtype":"command","commandType":"auto","position":34.0,"command":"# Cell 3: Build Gold Fact Tables (Fixed Ticket Join)\nfrom pyspark.sql.functions import col, lit, coalesce, to_date, expr, when\n\n# ==========================================\n# 1. FACT TICKETS (Customer Support)\n# ==========================================\n# Fix: Removed join to dim_cell because Tickets don't have cell_id.\n# We default cell_sk to -1 (Unknown).\nfrom pyspark.sql.functions import col, lit, coalesce, to_date, expr, when\n\nprint(\"Building Fact Tickets (With Cell Link)...\")\n\ndf_tickets_silver = spark.table(\"telecom_lakehouse.silver.fact_tickets\").alias(\"f\")\n\n# JOIN LOGIC:\n# 1. Join Customer (Who complained?)\n# 2. Join Cell (Where did they complain? - NOW ENABLED)\n# 3. Join Issue Type (What was the complaint?)\n\ndf_tickets_gold = (df_tickets_silver \n    .join(spark.table(\"telecom_lakehouse.gold.dim_customer\").filter(\"is_current=true\").alias(\"u\"), col(\"f.customer_id\") == col(\"u.customer_id\"), \"left\") \n    .join(spark.table(\"telecom_lakehouse.gold.dim_cell\").filter(\"is_current=true\").alias(\"c\"), col(\"f.cell_id\") == col(\"c.cell_id\"), \"left\") \n    .join(spark.table(\"telecom_lakehouse.gold.dim_issue_type\").alias(\"i\"), col(\"f.issue_type\") == col(\"i.issue_type\"), \"left\") \n    .withColumn(\"date_key\", to_date(\"created_ts\")) \n    .select(\n        col(\"f.ticket_id\"),\n        coalesce(col(\"u.customer_sk\"), lit(-1)).alias(\"customer_sk\"),\n        \n        # FIX: Now we use the actual Cell SK from the join!\n        coalesce(col(\"c.cell_sk\"), lit(-1)).alias(\"cell_sk\"),\n        \n        coalesce(col(\"i.issue_sk\"), lit(-1)).alias(\"issue_sk\"),\n        col(\"date_key\"),\n        col(\"f.created_ts\"),\n        col(\"f.priority\"),\n        col(\"f.status\"),\n        col(\"f.resolution_time_min\"),\n        col(\"f.region_id\")\n    )\n)\n\ndf_tickets_gold.write.format(\"delta\").mode(\"overwrite\").option(\"mergeSchema\", \"true\").saveAsTable(\"telecom_lakehouse.gold.fact_tickets\")\n\nprint(\"Fact Tickets Built (Linked to Cell, Customer, and Issue).\")\n\n\n\n# ==========================================\n# 2. FACT QoS (Network Performance)\n# ==========================================\nprint(\"Building Fact QoS...\")\n\ndf_qos_silver = spark.table(\"telecom_lakehouse.silver.fact_qos\").alias(\"f\")\n\ndf_qos_gold = (df_qos_silver \n    .join(spark.table(\"telecom_lakehouse.gold.dim_cell\").filter(\"is_current=true\").alias(\"c\"), col(\"f.cell_id\") == col(\"c.cell_id\"), \"left\") \n    .withColumn(\"date_key\", to_date(\"event_ts\")) \n    .withColumn(\"qos_score\", expr(\"100 - (coalesce(latency_ms,0)*0.1) - (coalesce(packet_loss_pct,0)*5)\")) \n    .withColumn(\"congestion_candidate\", when((col(\"throughput_mbps\") < 1.0) & (col(\"signal_rsrp_dbm\") > -100), 1).otherwise(0)) \n    .select(\n        col(\"f.qos_event_id\"),\n        coalesce(col(\"c.cell_sk\"), lit(-1)).alias(\"cell_sk\"),\n        col(\"date_key\"),\n        col(\"f.event_ts\"),\n        col(\"qos_score\"),\n        col(\"f.throughput_mbps\"),\n        col(\"f.latency_ms\"),\n        col(\"f.packet_loss_pct\"),\n        col(\"f.jitter_ms\"),\n        col(\"congestion_candidate\"),\n        col(\"f.region_id\")\n    )\n)\n\ndf_qos_gold.write.format(\"delta\").mode(\"overwrite\").option(\"mergeSchema\", \"true\").saveAsTable(\"telecom_lakehouse.gold.fact_qos\")\n\n\n# Cell 3 (Part 3): Fact Sessions (With Derived Drop Reason)\nprint(\"Building Fact Sessions...\")\n\ndf_sess_silver = spark.table(\"telecom_lakehouse.silver.fact_sessions\").alias(\"f\")\n\ndf_sess_gold = (df_sess_silver \n    .join(spark.table(\"telecom_lakehouse.gold.dim_cell\").filter(\"is_current=true\").alias(\"c\"), col(\"f.cell_id\") == col(\"c.cell_id\"), \"left\") \n    .join(spark.table(\"telecom_lakehouse.gold.dim_customer\").filter(\"is_current=true\").alias(\"u\"), col(\"f.customer_id\") == col(\"u.customer_id\"), \"left\") \n    .withColumn(\"date_key\", to_date(\"session_start_ts\")) \n    \n    # 1. Derived Status\n    .withColumn(\"session_status\", when(col(\"dropped_flag\") == 1, \"DROPPED\").otherwise(\"SUCCESS\")) \n    \n    # 2. Derived Quality Score\n    .withColumn(\"session_quality_score\", \n        when(col(\"dropped_flag\") == 1, 0)\n        .when(col(\"duration_sec\") < 10, 50)\n        .otherwise(100))\n    \n    # 3. COMPUTE MISSING DROP REASON (The Logic)\n    .withColumn(\"drop_reason\", \n        when(col(\"dropped_flag\") == 0, \"Normal Termination\")\n        .when((col(\"dropped_flag\") == 1) & (col(\"duration_sec\") < 5), \"Setup Failure\")\n        .when((col(\"dropped_flag\") == 1) & (col(\"app_category\").isin(\"Gaming\", \"Video\", \"Streaming\")), \"Bandwidth/Latency Timeout\")\n        .when((col(\"dropped_flag\") == 1), \"Signal Loss / Coverage Hole\") # Default for Browsing/Others\n        .otherwise(\"Unknown\")\n    )\n    \n    .select(\n        col(\"f.session_id\"),\n        coalesce(col(\"u.customer_sk\"), lit(-1)).alias(\"customer_sk\"),\n        coalesce(col(\"c.cell_sk\"), lit(-1)).alias(\"cell_sk\"),\n        col(\"date_key\"),\n        col(\"f.session_start_ts\"),\n        col(\"f.session_end_ts\"),\n        col(\"f.duration_sec\"),\n        col(\"f.data_mb\"),\n        col(\"session_quality_score\"),\n        col(\"f.dropped_flag\"),\n        col(\"drop_reason\"),       # Now populated with our logic!\n        col(\"f.app_category\"),\n        col(\"f.device_id\"),\n        col(\"session_status\")\n    )\n)\n\ndf_sess_gold.write.format(\"delta\").mode(\"overwrite\").option(\"mergeSchema\", \"true\").saveAsTable(\"telecom_lakehouse.gold.fact_sessions\")\n\nprint(\"Fact Sessions Built (Derived drop_reason populated).\")","commandVersion":4,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"5d0c9a88-9135-42b7-8ffc-fdec59b5e9c8"},{"version":"CommandV1","origId":1423076379966156,"guid":"ebec03c4-0e99-4260-bba6-d021c2072419","subtype":"command","commandType":"auto","position":34.5,"command":"%md\n## optimization","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"32d462c4-f3d3-4e09-9582-726af1fc3d9d"},{"version":"CommandV1","origId":1423076379966157,"guid":"3aee3eeb-f430-458f-b170-412d69d22a2c","subtype":"command","commandType":"auto","position":35.0,"command":"tickets_part_df = spark.table(\"telecom_lakehouse.gold.fact_tickets\")\n(tickets_part_df\n .write\n .format(\"delta\")\n .mode(\"overwrite\")\n .partitionBy(\"issue_sk\")\n .saveAsTable(\"telecom_lakehouse.gold.fact_tickets_v2\"))","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"98d80e0c-1a12-4ba2-a1e3-478cd92709f3"},{"version":"CommandV1","origId":1423076379966158,"guid":"3eddb40f-fc3e-485c-a393-c84611b44d09","subtype":"command","commandType":"auto","position":36.0,"command":"qos_df = spark.table(\"telecom_lakehouse.gold.fact_qos\")\n\n(qos_df\n .write\n .format(\"delta\")\n .mode(\"overwrite\")\n .partitionBy(\"date_key\")\n .saveAsTable(\"telecom_lakehouse.gold.fact_qos_v2\"))\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[