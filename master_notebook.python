{"version":"NotebookV1","origId":1423076379966119,"name":"master_notebook","language":"python","commands":[{"version":"CommandV1","origId":5632337588093605,"guid":"12378ca5-6835-43a7-8fc3-35da34779e25","subtype":"command","commandType":"auto","position":22.5,"command":"%sql\nupdate telecom_lakehouse.silver.fact_tickets set issue_type = \"BILLING\" where issue_type = \"billing\";\nupdate telecom_lakehouse.silver.fact_tickets set issue_type = \"DROP\" where issue_type = \"drop\";\nupdate telecom_lakehouse.silver.fact_tickets set issue_type = \"NETWORK\" where issue_type = \"network\";\nupdate telecom_lakehouse.silver.fact_tickets set issue_type = \"SLOW_DATA\" where issue_type = \"slow_data\";","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"79ed5d16-5077-44e2-b8ce-f8322651ae48"},{"version":"CommandV1","origId":7479023694147409,"guid":"4880b874-0668-40df-ac48-13152a7d12c7","subtype":"command","commandType":"auto","position":29.5,"command":"%sql\n    \ncreate or replace table telecom_lakehouse.silver.fact_tickets as\nselect ticket_id,customer_id,region as region_id, cell_id, issue_type,priority,cast(created_ts as timestamp), status,cast(resolution_time_min as double),_rescued_data,_ingestion_ts\nfrom telecom_lakehouse.silver.fact_tickets;","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"d3cbbbd0-78a9-4ade-b4db-baf1cdeea01c"},{"version":"CommandV1","origId":7479023694147318,"guid":"7097027b-787c-42d6-8de7-5f4fb90c0689","subtype":"command","commandType":"auto","position":2.5,"command":"tickets_input_path = f\"{volume_path}/tickets\"\ntickets_checkpoint = f\"{volume_path}/checkpoints/tickets\"\n\ndf_tickets_stream = (spark.readStream\n    .format(\"cloudFiles\")\n    .option(\"cloudFiles.format\", \"csv\")\n    .option(\"cloudFiles.schemaLocation\", tickets_checkpoint)\n    .option(\"header\", \"true\")\n    .option(\"inferSchema\", \"true\")\n    .load(tickets_input_path)\n)\n\n(df_tickets_stream.withColumn(\"_ingestion_ts\", current_timestamp())\n    .writeStream\n    .format(\"delta\")\n    .option(\"checkpointLocation\", tickets_checkpoint)\n    .trigger(availableNow=True)\n    .toTable(\"telecom_lakehouse.bronze.tickets_raw\")\n)","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"c1ddf01c-5d4e-403b-9daa-1357ce5bb6f9"},{"version":"CommandV1","origId":1423076379966120,"guid":"2a89fead-1be7-4d37-93cd-60f641d8a118","subtype":"command","commandType":"auto","position":0.5,"command":"%md\n## Data Loading","commandVersion":3,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"fa3cea78-45af-4144-9cbf-448dfee70ff4"},{"version":"CommandV1","origId":1423076379966121,"guid":"5da6f7ce-7630-497c-b5f4-d50034f657bf","subtype":"command","commandType":"auto","position":1.0,"command":"from pyspark.sql.functions import current_timestamp\n\n\nvolume_path = \"/Volumes/telecom_lakehouse/bronze/landing_zone\"\nqos_input_path = f\"{volume_path}/qos\" \ncheckpoint_path = f\"{volume_path}/checkpoints/qos\"\n\n# STREAMING READ using Auto Loader\n# \"schema drift (new KPIs added: nr5g_band, signal_rsrp_dbm)\"\ndf_qos_stream = (spark.readStream\n    .format(\"cloudFiles\")\n    .option(\"cloudFiles.format\", \"csv\")\n    .option(\"cloudFiles.schemaLocation\", checkpoint_path)\n    .option(\"cloudFiles.schemaEvolutionMode\", \"addNewColumns\") \n    .option(\"header\", \"true\")\n    .option(\"inferSchema\", \"true\") \n    .load(qos_input_path)\n)\n\n\ndf_qos_bronze = df_qos_stream \\\n    .withColumn(\"_ingestion_ts\", current_timestamp()) \\\n    .withColumn(\"_source_file\", df_qos_stream[\"_metadata.file_path\"])\n\n\n(df_qos_bronze.writeStream\n    .format(\"delta\")\n    .option(\"checkpointLocation\", checkpoint_path)\n    .option(\"mergeSchema\", \"true\")\n    .trigger(availableNow=True)\n    .toTable(\"telecom_lakehouse.bronze.raw_qos_logs\")\n)","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"685fcf03-4df8-4ea4-9e27-4f3c5d473f3a"},{"version":"CommandV1","origId":1423076379966122,"guid":"f5d638a9-231e-4130-9e7a-ecc8f2132512","subtype":"command","commandType":"auto","position":2.0,"command":"from pyspark.sql.functions import current_timestamp\nvolume_path = \"/Volumes/telecom_lakehouse/bronze/landing_zone\"\nsessions_input_path = f\"{volume_path}/sessions\"\nsessions_checkpoint = f\"{volume_path}/checkpoints/sessions\"\n\ndf_sessions_stream = (spark.readStream\n    .format(\"cloudFiles\")\n    .option(\"cloudFiles.format\", \"csv\")\n    .option(\"cloudFiles.schemaLocation\", sessions_checkpoint)\n    .option(\"cloudFiles.schemaEvolutionMode\", \"addNewColumns\")\n    .option(\"header\", \"true\")\n    .option(\"inferSchema\", \"true\")\n    .load(sessions_input_path)\n)\n\n(df_sessions_stream.withColumn(\"_ingestion_ts\", current_timestamp())\n    .writeStream\n    .format(\"delta\")\n    .option(\"checkpointLocation\", sessions_checkpoint)\n    .option(\"mergeSchema\", \"true\")\n    .trigger(availableNow=True)\n    .toTable(\"telecom_lakehouse.bronze.session_raw\")\n)","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"673db83b-78d6-4d90-9628-0aec9d11d668"},{"version":"CommandV1","origId":1423076379966123,"guid":"15e6f7b7-c572-43cc-afae-025c5d000ea6","subtype":"command","commandType":"auto","position":3.0,"command":"# Notebook: 02_Reference_Fix (Patch)\nfrom pyspark.sql.functions import col, lit\n\n# 1. Read Raw Logs\n# 2. Select 'region', Rename to 'region_id', Add placeholders\n# 3. FORCE overwrite the table schema\nspark.table(\"telecom_lakehouse.bronze.raw_qos_logs\") \\\n    .select(\"region\").distinct() \\\n    .withColumnRenamed(\"region\", \"region_id\") \\\n    .withColumn(\"region_name\", col(\"region_id\")) \\\n    .withColumn(\"circle\", lit(\"Unknown\")) \\\n    .write \\\n    .format(\"delta\") \\\n    .mode(\"overwrite\") \\\n    .option(\"overwriteSchema\", \"true\") \\\n    .saveAsTable(\"telecom_lakehouse.reference.dim_regions\")\n\nprint(\"Fixed: dim_regions now contains 'region_id' (Schema Overwritten).\")","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"1560b39b-ca67-45f4-9129-2cc1a7977453"},{"version":"CommandV1","origId":1423076379966124,"guid":"6d8c8b47-339a-4509-84d8-96dcf520aaa1","subtype":"command","commandType":"auto","position":4.0,"command":"%md\n## reference loader","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"453f1406-379e-41a2-a671-4893fc28591d"},{"version":"CommandV1","origId":1423076379966125,"guid":"fa6f80b4-23b7-4529-a3b0-5ceebcf28ceb","subtype":"command","commandType":"auto","position":5.0,"command":"# Notebook: 02_Reference_Data_And_Profiling_Corrected\n# Language: Python\n\nfrom pyspark.sql.functions import col, count, lit, upper, regexp_replace, current_timestamp\nfrom pyspark.sql.utils import AnalysisException\n\n# ====================================================\n# PART 1: LOAD & INFER DIMENSIONS\n# ====================================================\n\n# Path to your uploaded CSVs\n# NOTE: Ensure you uploaded 'cells.csv' and 'customers.csv' to this path\nvolume_path = \"/Volumes/telecom_lakehouse/reference/ref_vol\"\n\n# --- A. Load Existing CSVs ---\n\n# 1. Load Cells (Source: cells.csv)\ntry:\n    df_cells = spark.read.format(\"csv\").option(\"header\", \"true\").load(f\"{volume_path}/cells.csv\")\n    \n    # Standardize cell_id\n    df_cells = df_cells.withColumn(\"cell_id\", upper(regexp_replace(col(\"cell_id\"), \"[^a-zA-Z0-9]\", \"\")))\n    \n    # Save to Delta\n    df_cells.write.mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.reference.dim_cells\")\n    print(\"dim_cells loaded.\")\nexcept Exception as e:\n    print(f\"Error loading cells.csv: {e}\")\n\n# 2. Load Customers (Source: customers.csv)\ntry:\n    df_cust = spark.read.format(\"csv\").option(\"header\", \"true\").load(f\"{volume_path}/customers.csv\")\n    df_cust.write.mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.reference.dim_customers\")\n    print(\"dim_customers loaded.\")\nexcept Exception as e:\n    print(f\"Error loading customers.csv: {e}\")\n\n\n# --- B. Infer Missing Dimensions from Bronze Data ---\n# These tables don't exist as CSVs, so we build them from the raw logs.\n\n# 3. Infer Regions (from QoS Logs)\n# spark.table(\"telecom_lakehouse.bronze.raw_qos_logs\") \\\n#     .select(\"region\").distinct() \\\n#     .withColumn(\"region_name\", col(\"region\")) \\\n#     .withColumn(\"circle\", lit(\"Unknown\")) \\\n#     .write.mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.reference.dim_regions\")\n\n# 4. Infer Devices (from QoS Logs)\n# REMOVED: device_class block, as device_class does not exist in raw_qos_logs\n\n# 5. Infer Issue Types (from Tickets)\nspark.table(\"telecom_lakehouse.bronze.tickets_raw\") \\\n    .select(\"issue_type\").distinct() \\\n    .withColumn(\"category\", lit(\"General\")) \\\n    .write.mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.reference.dim_issue_types\")\n\nprint(\"Step 1 Complete: All reference tables prepared.\")\n\n\n# ====================================================\n# PART 2: REFERENCE CHECKS (PROFILING)\n# ====================================================\n\nquality_results = []\n\n# --- Check 1: Duplicate Keys (cell_id) ---\n# We check if 'cell_id' is unique in dim_cells\ndup_cells = spark.table(\"telecom_lakehouse.reference.dim_cells\") \\\n    .groupBy(\"cell_id\").count().filter(col(\"count\") > 1).count()\nstatus = \"FAIL\" if dup_cells > 0 else \"PASS\"\nquality_results.append((\"dim_cells\", \"Duplicate cell_id check\", int(dup_cells), status))\n\n# --- Check 2: Duplicate Keys (customer_id) ---\n# We check if 'customer_id' is unique in dim_customers\ndup_cust = spark.table(\"telecom_lakehouse.reference.dim_customers\") \\\n    .groupBy(\"customer_id\").count().filter(col(\"count\") > 1).count()\nstatus = \"FAIL\" if dup_cust > 0 else \"PASS\"\nquality_results.append((\"dim_customers\", \"Duplicate customer_id check\", int(dup_cust), status))\n\n# --- Check 3: Cells without Region Mapping ---\n# CRITICAL FIX: The provided 'cells.csv' DOES NOT have a 'region_id' column.\n# We must check if the column exists before trying to join, otherwise code crashes.\n\ndf_cells_table = spark.table(\"telecom_lakehouse.reference.dim_cells\")\ndf_regions_table = spark.table(\"telecom_lakehouse.reference.dim_regions\")\n\n# if \"region\" in df_cells_table.columns:\n#     # If column exists, perform the logic check\n#     missing_regions = df_cells_table.join(df_regions_table, \"region\", \"left_anti\").count()\n#     status = \"FAIL\" if missing_regions > 0 else \"PASS\"\nmissing_regions = spark.sql(\"select * from telecom_lakehouse.reference.dim_cells as c left join telecom_lakehouse.bronze.raw_qos_logs as q on c.cell_id = q.cell_id where q.qos_event_id is null\")\nquality_results.append((\"dim_cells\", \"Cells without valid Region mapping\", missing_regions.count(), status))\n# else:\n#     # If column missing, Flag it as Schema Issue (Don't crash)\n#     quality_results.append((\"dim_cells\", \"Cells without valid Region mapping\", 0, \"FAIL - Column region_id missing in CSV\"))\n\n# --- Check 4: Device Models missing Device Class ---\n# REMOVED: device_class check, as device_class does not exist in dim_devices\n\n\n# ====================================================\n# PART 3: GENERATE REPORT TABLE\n# ====================================================\n\n# Create DataFrame from results\nschema = [\"table_name\", \"check_description\", \"failed_record_count\", \"status\"]\ndf_report = spark.createDataFrame(quality_results, schema)\n\n# Add timestamp\ndf_report_final = df_report.withColumn(\"check_timestamp\", current_timestamp())\n\n# Write to Delta Table\ndf_report_final.write.format(\"delta\").mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.reference.reference_quality_report\")\n\n# Display Result\ndisplay(df_report_final)\n","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"e5d6c9f7-1f64-4464-b6a2-50252426248a"},{"version":"CommandV1","origId":1423076379966126,"guid":"20c42d06-f759-4347-af1a-9a9d7ef6c89c","subtype":"command","commandType":"auto","position":6.0,"command":"%md\n## silver","commandVersion":2,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"9422248e-8cf0-41e8-8c67-f6a153b7bb1d"},{"version":"CommandV1","origId":1423076379966127,"guid":"76f944e0-532b-49fd-8f9c-74433151a670","subtype":"command","commandType":"auto","position":7.0,"command":"# Cell 1: Setup \nfrom pyspark.sql.functions import (col, upper, regexp_replace, when, lit, to_timestamp, \n                                   expr, split, current_timestamp, to_date, coalesce, lag)\nfrom pyspark.sql.window import Window\nfrom delta.tables import *\n\n\nspark.sql(\"\"\"\nCREATE TABLE IF NOT EXISTS telecom_lakehouse.silver.dq_rule_registry (\n    rule_id STRING, dataset STRING, description STRING, \n    severity STRING, action STRING, owner STRING\n)\n\"\"\")\n\n# Register Rules \nrules_list = [\n    (\"DQ_QOS_01\", \"QoS\", \"Throughput must be >= 0\", \"CRITICAL\", \"QUARANTINE\", \"NetOps\"),\n    (\"DQ_QOS_02\", \"QoS\", \"Packet Loss between 0-100%\", \"CRITICAL\", \"QUARANTINE\", \"NetOps\"),\n    (\"DQ_QOS_03\", \"QoS\", \"Latency > 500ms (High Lag)\", \"WARNING\", \"FLAG\", \"NetOps\"),\n    (\"DQ_SESS_01\", \"Sessions\", \"Duration must be positive\", \"CRITICAL\", \"QUARANTINE\", \"CustOps\"),\n    (\"DQ_SESS_02\", \"Sessions\", \"Data Usage must be positive\", \"CRITICAL\", \"QUARANTINE\", \"CustOps\"),\n    (\"DQ_TKT_01\", \"Tickets\", \"Missing Cell ID\", \"WARNING\", \"DEFAULT_UNKNOWN\", \"Support\"),\n    (\"DQ_TKT_02\", \"Tickets\", \"Resolution Time < 0\", \"CRITICAL\", \"QUARANTINE\", \"Support\"),\n    (\"DQ_TKT_03\", \"Tickets\", \"Status is open but resolution time is filled\", \"CRITICAL\", \"QUARANTINE\", \"Support\")\n]\nspark.createDataFrame(rules_list, [\"rule_id\", \"dataset\", \"description\", \"severity\", \"action\", \"owner\"]) \\\n    .write.mode(\"overwrite\").saveAsTable(\"telecom_lakehouse.silver.dq_rule_registry\")\n\n# 3. Canonicalization Functions \ndef normalize_cell_id(col_name):\n    # Strip hyphens, upper, keep only alphanumeric (CELL-001 -> CELL001)\n    return upper(regexp_replace(col_name, \"[^a-zA-Z0-9]\", \"\"))\n\ndef normalize_device_model(col_name):\n    # Simple upper case for now (Mapping table logic can be added via joins later)\n    return upper(col_name)\n\ndef normalize_technology(col_name):\n    # Normalize 4G/LTE -> 4G, 5G/NR -> 5G\n    return when(upper(col_name).rlike(\"LTE|4G\"), \"4G\") \\\n           .when(upper(col_name).rlike(\"NR|5G\"), \"5G\") \\\n           .otherwise(\"UNKNOWN\")\n\ndef normalize_priority(col_name):\n    # High/P1 -> P1\n    return when(upper(col_name).isin(\"P1\", \"HIGH\", \"CRITICAL\"), \"P1\") \\\n           .when(upper(col_name).isin(\"P2\", \"MEDIUM\"), \"P2\") \\\n           .otherwise(\"P3\")\n\n# 4. Create Quarantine Tables (With Metadata Columns)\nspark.sql(\"\"\"CREATE TABLE IF NOT EXISTS telecom_lakehouse.quarantine.qos_rejected \n             (qos_event_id STRING, reject_reason STRING, rule_id STRING, ingest_ts TIMESTAMP, _source_file STRING)\"\"\")\nspark.sql(\"\"\"CREATE TABLE IF NOT EXISTS telecom_lakehouse.quarantine.sessions_rejected \n             (session_id STRING, reject_reason STRING, rule_id STRING, ingest_ts TIMESTAMP, _source_file STRING)\"\"\")\nspark.sql(\"\"\"CREATE TABLE IF NOT EXISTS telecom_lakehouse.quarantine.tickets_rejected \n             (ticket_id STRING, reject_reason STRING, rule_id STRING, ingest_ts TIMESTAMP, _source_file STRING)\"\"\")\n\nprint(\"Setup Complete: Registry, Functions, and Quarantine Tables ready.\")","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"d6e17823-9335-4aed-8485-2a6671a075f8"},{"version":"CommandV1","origId":1423076379966128,"guid":"765fd84a-2414-4365-831f-9d1f0242d0d2","subtype":"command","commandType":"auto","position":8.0,"command":"# Cell 2: QoS Logic \nfrom pyspark.sql.functions import col, to_timestamp, expr, split, when, upper, regexp_replace, coalesce\n\ndef process_qos_batch(df_batch, batch_id):\n    # 1. Deduplicate\n    # Keep the row with the latest ingestion timestamp\n    df_dedup = df_batch.withColumn(\"rank\", expr(\"row_number() over (partition by qos_event_id order by _ingestion_ts desc)\")) \\\n                       .filter(\"rank = 1\").drop(\"rank\")\n\n    # 2. Transform \n    # FIX: Use 'expr' with 'try_to_timestamp' to handle literals correctly and avoid crashes\n    df_trans = df_dedup \\\n        .withColumn(\"event_ts\", \n            coalesce(\n                expr(\"try_to_timestamp(event_ts, 'M/d/yyyy HH:mm')\"),      # Fixes '1/9/2025 10:00'\n                expr(\"try_to_timestamp(event_ts, 'yyyy-MM-dd HH:mm:ss')\"), # Standard ISO\n                expr(\"try_cast(event_ts as timestamp)\")                    # Safe fallback\n            )\n        ) \\\n        .withColumnRenamed(\"region\", \"region_id\") \\\n        .withColumn(\"latency_ms\", col(\"latency_ms\").cast(\"double\")) \\\n        .withColumn(\"jitter_ms\", col(\"jitter_ms\").cast(\"double\")) \\\n        .withColumn(\"packet_loss_pct\", col(\"packet_loss_pct\").cast(\"double\")) \\\n        .withColumn(\"throughput_mbps\", col(\"throughput_mbps\").cast(\"double\")) \\\n        .withColumn(\"signal_rsrp_dbm\", col(\"signal_rsrp_dbm\").cast(\"double\")) \\\n        .withColumn(\"cell_id\", upper(regexp_replace(col(\"cell_id\"), \"[^a-zA-Z0-9]\", \"\"))) \\\n        .withColumn(\"technology\", \n             when(upper(col(\"technology\")).rlike(\"LTE|4G\"), \"4G\")\n            .when(upper(col(\"technology\")).rlike(\"NR|5G\"), \"5G\")\n            .otherwise(\"UNKNOWN\")\n        )\n\n    # 3. DQ Checks\n    df_tagged = df_trans.withColumn(\"dq_status\", \n        when(col(\"throughput_mbps\") < 0, \"REJECT:DQ_QOS_01\")\n        .when((col(\"packet_loss_pct\") < 0) | (col(\"packet_loss_pct\") > 100), \"REJECT:DQ_QOS_02\")\n        .otherwise(\"PASS\")\n    )\n\n    # 4. Split & Write\n    df_valid = df_tagged.filter(\"dq_status = 'PASS'\").drop(\"dq_status\")\n    \n    df_reject = df_tagged.filter(\"dq_status LIKE 'REJECT%'\") \\\n        .select(\n            \"qos_event_id\", \n            col(\"dq_status\").alias(\"reject_reason\"), \n            split(col(\"dq_status\"), \":\").getItem(1).alias(\"rule_id\"), \n            col(\"_ingestion_ts\").alias(\"ingest_ts\")\n        )\n\n    # Write Valid -> Silver\n    df_valid.write.format(\"delta\") \\\n        .mode(\"append\") \\\n        .option(\"mergeSchema\", \"true\") \\\n        .saveAsTable(\"telecom_lakehouse.silver.fact_qos\")\n        \n    # Write Rejected -> Quarantine\n    df_reject.write.format(\"delta\") \\\n        .mode(\"append\") \\\n        .saveAsTable(\"telecom_lakehouse.quarantine.qos_rejected\")\n\n# Run Stream\nprint(\"Starting QoS Stream (ANSI Safe)...\")\n(spark.readStream.table(\"telecom_lakehouse.bronze.raw_qos_logs\")\n    .writeStream\n    .foreachBatch(process_qos_batch)\n    .option(\"checkpointLocation\", \"/Volumes/telecom_lakehouse/bronze/landing_zone/checkpoints/qos_silver_final_v3\")\n    .trigger(availableNow=True)\n    .start()\n    .awaitTermination()\n)\nprint(\"QoS Done.\")","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"1ada371d-7a00-4d54-a6da-7daeedca6f93"},{"version":"CommandV1","origId":1423076379966129,"guid":"1189dcfb-85e9-4fd1-9b7e-246c8c7e1be2","subtype":"command","commandType":"auto","position":9.0,"command":"# Cell 3: Sessions Logic (Final Fix - Indentation Corrected)\nfrom pyspark.sql.functions import col, expr, split, when, upper, lower, trim, regexp_replace, coalesce, lit, current_timestamp\n\ndef process_sessions_batch(df_batch, batch_id):\n    # 1. Deduplicate\n    df_dedup = df_batch.withColumn(\"rank\", expr(\"row_number() over (partition by session_id order by _ingestion_ts desc)\")) \\\n                       .filter(\"rank = 1\").drop(\"rank\")\n\n    # 2. Transform & Clean\n    # We use 'try_to_timestamp' to handle date formats safely\n    df_trans = df_dedup \\\n        .withColumn(\"session_start_ts\", coalesce(expr(\"try_to_timestamp(session_start_ts, 'M/d/yyyy HH:mm')\"), expr(\"try_to_timestamp(session_start_ts)\"))) \\\n        .withColumn(\"session_end_ts_raw\", coalesce(expr(\"try_to_timestamp(session_end_ts, 'M/d/yyyy HH:mm')\"), expr(\"try_to_timestamp(session_end_ts)\"))) \\\n        .withColumn(\"session_end_ts\", \n            when(col(\"session_end_ts_raw\").isNull() & (col(\"dropped_flag\") == 1), col(\"_ingestion_ts\"))\n            .otherwise(col(\"session_end_ts_raw\"))) \\\n        .drop(\"session_end_ts_raw\") \\\n        .withColumn(\"cell_id\", upper(trim(regexp_replace(col(\"cell_id\"), \"[^a-zA-Z0-9]\", \"\")))) \\\n        .withColumn(\"app_category\", lower(trim(col(\"app_category\")))) \\\n        .withColumn(\"data_mb\", col(\"data_mb\").cast(\"double\"))\n\n    # 3. Handle Outliers\n    df_cleaned = df_trans.withColumn(\"data_mb\", \n        when(col(\"data_mb\") > 10000, 10000)\n        .when(col(\"data_mb\") < 0, lit(None))\n        .otherwise(col(\"data_mb\"))\n    )\n\n    # 4. Derive Duration & Status\n    df_final = df_cleaned \\\n        .withColumn(\"duration_sec\", \n            when(col(\"session_end_ts\").isNotNull(), (col(\"session_end_ts\").cast(\"long\") - col(\"session_start_ts\").cast(\"long\")))\n            .otherwise(0)) \\\n        .withColumn(\"session_status\", \n            when(col(\"dropped_flag\") == 1, \"DROPPED\")\n            .otherwise(\"COMPLETED\")) \\\n        .withColumn(\"_processed_ts\", current_timestamp())\n\n    # 5. DQ Checks\n    df_tagged = df_final.withColumn(\"dq_status\", \n        when(col(\"duration_sec\") < 0, \"REJECT:Negative Duration\")\n        .when(col(\"customer_id\").isNull(), \"REJECT:Missing Customer ID\")\n        .otherwise(\"PASS\")\n    )\n\n    # 6. Split & Write\n    df_valid = df_tagged.filter(\"dq_status = 'PASS'\").drop(\"dq_status\")\n    \n    # Schema cleanup\n    if \"region\" in df_valid.columns:\n        df_valid = df_valid.drop(\"region\")\n\n    df_valid.write.format(\"delta\").mode(\"append\").option(\"mergeSchema\", \"true\").saveAsTable(\"telecom_lakehouse.silver.fact_sessions\")\n    \n    # Quarantine\n    df_reject = df_tagged.filter(\"dq_status LIKE 'REJECT%'\") \\\n        .select(\n            \"session_id\", \n            col(\"dq_status\").alias(\"reject_reason\"), \n            expr(\"'DQ_RULE'\").alias(\"rule_id\"), \n            col(\"_ingestion_ts\").alias(\"ingest_ts\")\n        )\n    df_reject.write.format(\"delta\").mode(\"append\").saveAsTable(\"telecom_lakehouse.quarantine.sessions_rejected\")\n\n# Run Stream\nprint(\"Starting Sessions Stream...\")\n(spark.readStream.table(\"telecom_lakehouse.bronze.session_raw\")\n    .writeStream\n    .foreachBatch(process_sessions_batch)\n    .option(\"checkpointLocation\", \"/Volumes/telecom_lakehouse/bronze/landing_zone/checkpoints/sessions_silver_v6\")\n    .trigger(availableNow=True)\n    .start()\n    .awaitTermination()\n)\nprint(\"Sessions Done.\")","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"fab8f5f4-8edf-473b-84fe-e610096da953"},{"version":"CommandV1","origId":1423076379966130,"guid":"cc57b935-3c62-483d-b169-b975af0ab04c","subtype":"command","commandType":"auto","position":10.0,"command":"# Creation of tickets table\nfrom pyspark.sql.functions import *","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"0b335e7b-aa8d-4f6e-8692-8cd1d78fc899"},{"version":"CommandV1","origId":1423076379966131,"guid":"c4e8ad62-2487-48de-a1e0-c47ab063db29","subtype":"command","commandType":"auto","position":11.0,"command":"df_bronze = spark.table(\"telecom_lakehouse.bronze.tickets_raw\")\n\ntotal_bronze = df_bronze.count()\nprint(f\"Total bronze rows : {total_bronze}\")\n\ndf_bronze.printSchema()\ndisplay(df_bronze.limit(5))","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"9d387993-064c-429b-833a-5292320fdb34"},{"version":"CommandV1","origId":1423076379966132,"guid":"4af3da3a-1fc7-4fde-8d1e-c3efb264728b","subtype":"command","commandType":"auto","position":12.0,"command":"df_dedup = df_bronze.dropDuplicates([\"ticket_id\"])","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"766bdc71-c90a-4201-82ea-913b4275acf0"},{"version":"CommandV1","origId":1423076379966133,"guid":"25227698-456a-4b0c-8bb0-97804f8b3911","subtype":"command","commandType":"auto","position":13.0,"command":"# 3. Clean & normalize priority (drift: P1/p2/High)\ndf_priority_clean = df_dedup.withColumn(\n    \"priority\",\n    when(lower(col(\"priority\")).isin(\"p1\", \"high\"), \"P1\")\n    .when(lower(col(\"priority\")).isin(\"p2\", \"medium\"), \"P2\")\n    .when(lower(col(\"priority\")).isin(\"p3\", \"low\"), \"P3\")\n    .otherwise(\"UNKNOWN\")\n)\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"45f1e1b1-012e-4ad0-8632-1c9076897583"},{"version":"CommandV1","origId":1423076379966134,"guid":"9048c7cc-a37a-4e46-8a6f-66e58af09cfd","subtype":"command","commandType":"auto","position":14.0,"command":"# 4. Clean & normalize status (open/closed drift)\ndf_status_clean = df_priority_clean.withColumn(\n    \"status\",\n    when(lower(col(\"status\")).isin(\"open\", \"opened\"), \"OPEN\")\n    .when(lower(col(\"status\")).isin(\"closed\", \"resolved\"), \"CLOSED\")\n    .otherwise(\"UNKNOWN\")\n)\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"96087378-004a-4a2f-934a-2ba7a6252ab9"},{"version":"CommandV1","origId":1423076379966135,"guid":"5573c49d-5289-49d8-bcea-aa524966e37d","subtype":"command","commandType":"auto","position":15.0,"command":"# 5. Clean issue_type (noise reduction)\ndf_issue_clean = df_status_clean.withColumn(\n    \"issue_type\",\n    lower(trim(col(\"issue_type\")))\n)\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"7d249943-9b88-4532-b989-12aa9e7d0bdb"},{"version":"CommandV1","origId":1423076379966136,"guid":"77a70a37-5a93-4cde-b06e-9ddf0b64b734","subtype":"command","commandType":"auto","position":16.0,"command":"from pyspark.sql import functions as F\nfrom pyspark.sql.window import Window\n\n# ----------------------------------------------------\n# Step 1: Read Silver tables\n# ----------------------------------------------------\n\ndf_sessions_clean = spark.read.table(\"telecom_lakehouse.silver.fact_sessions\")\n\n# ----------------------------------------------------\n# Step 2: Get latest session cell per customer\n# ----------------------------------------------------\n\nsession_window = (\n    Window\n    .partitionBy(\"customer_id\")\n    .orderBy(F.col(\"session_end_ts\").desc_nulls_last())\n)\n\ndf_latest_session = (\n    df_sessions_clean\n    .filter(F.col(\"customer_id\").isNotNull())\n    .filter(F.col(\"cell_id\").isNotNull())\n    .withColumn(\"rn\", F.row_number().over(session_window))\n    .filter(F.col(\"rn\") == 1)\n    .select(\n        F.col(\"customer_id\"),\n        F.upper(F.trim(F.col(\"cell_id\"))).alias(\"session_cell_id\")\n    )\n)\n\n# ----------------------------------------------------\n# Step 3: Join tickets with latest session\n# ----------------------------------------------------\n\ndf_ticket_joined = (\n    df_issue_clean\n    .join(df_latest_session, on=\"customer_id\", how=\"left\")\n)\n\n# ----------------------------------------------------\n# Step 4: Resolve final cell_id\n# ----------------------------------------------------\n\ndf_ticket_cell_fixed = (\n    df_ticket_joined\n    .withColumn(\n        \"cell_id\",\n        F.when(\n            F.col(\"cell_id\").isNotNull(),\n            F.upper(F.trim(F.col(\"cell_id\")))\n        )\n        .when(\n            F.col(\"session_cell_id\").isNotNull(),\n            F.col(\"session_cell_id\")\n        )\n        .otherwise(F.lit(\"UNKNOWN\"))\n    )\n    .drop(\"session_cell_id\")\n)","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"086fb7b1-8ed9-4812-9d7b-5f7771e41eef"},{"version":"CommandV1","origId":1423076379966137,"guid":"d10018a7-3d73-4bbd-a11a-02963ba94036","subtype":"command","commandType":"auto","position":17.0,"command":"from pyspark.sql.functions import col, lit\n\ndf_q_dq_tkt_02 = (\n    df_ticket_cell_fixed\n    .filter(col(\"resolution_time_min\").cast(\"double\") < 0)\n    .select(\n        col(\"ticket_id\"),\n        lit(\"Resolution time is negative\").alias(\"reject_reason\"),\n        lit(\"DQ_TKT_02\").alias(\"rule_id\"),\n        col(\"_ingestion_ts\")\n    )\n)\n","commandVersion":1,"state":"input","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"sta